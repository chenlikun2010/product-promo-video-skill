# 阿里百炼 Bailian CLI (bl) TTS 配置
# 使用方法: source config/bailian.env
# 依赖: npm install -g bailian-cli  &&  bl auth login --console --console-site domestic

# 音色 ID (bl speech synthesize --list-voices --model cosyvoice-v3-flash 查看全部)
# 推荐音色:
#   longanwen_v3  优雅知性女声（默认，推荐公司/产品介绍）
#   longanli_v3   利落从容女（商务）
#   longanlang_v3 清爽利落男
#   longtian_v3   磁性理智男
#   longcheng_v3  智慧青年男
#   longanyang    阳光大男孩
BAILIAN_VOICE=longanwen_v3

# 语速 0.5-2.0，默认 1.0（正常语速）
BAILIAN_RATE=1.0

# 音调 0.5-2.0，默认 1.0
BAILIAN_PITCH=1.0

# 语言提示（一般不需改，默认 zh）
BAILIAN_LANGUAGE=zh

# 自然语言语气指令（可选，如希望更温暖/专业/活泼）
# 例: BAILIAN_INSTRUCT="用温暖亲切的语气，语速稍慢"
BAILIAN_INSTRUCT=
