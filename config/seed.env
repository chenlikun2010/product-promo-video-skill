# 火山引擎「大模型语音合成 Seed TTS」v3 凭证 —— 含密钥，勿外传。
# 用法: `source ~/.claude/skills/product-promo-video/config/seed.env`
export SEED_API_KEY="920ef48a-7191-4736-b9b1-c66f4dc1310d"
export SEED_RESOURCE_ID="seed-tts-2.0"   # saturn_* / *_uranus_* 大模型音色都走这个
export SEED_SPEAKER="zh_female_xiaohe_uranus_bigtts"   # 默认音色; 可在命令前 export 覆盖
# 可选: 自然语言语气/语速指令(留空则默认), 如 "用温暖亲切的语气，语速稍慢"
export SEED_INSTRUCT=""

# 已验证可用音色(换音色: export SEED_SPEAKER=<下面某个> 再跑脚本):
#   zh_female_xiaohe_uranus_bigtts            小荷·大模型女声(自然)
#   saturn_zh_female_qingyingduoduo_cs_tob    轻盈多多·大模型女声
#   saturn_zh_female_cancan_tob               灿灿·大模型女声
